generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PropertyType {
  WEG
  MV
}

enum StaffRole {
  MANAGER
  ACCOUNTANT
}

enum UnitType {
  APARTMENT
  OFFICE
  GARDEN
  PARKING
}

model User {
  id               String          @id @default(uuid())
  name             String
  email            String          @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  staffAssignments PropertyStaff[]
}

model PropertyStaff {
  id         String    @id @default(uuid())
  propertyId String
  userId     String
  role       StaffRole
  createdAt  DateTime  @default(now())
  property   Property  @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([propertyId, role])
}

model Property {
  id                 String          @id @default(uuid())
  name               String
  type               PropertyType
  propertyNumber     String          @unique
  declarationFileUrl String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  staff              PropertyStaff[]
  buildings          Building[]
}

model Building {
  id          String   @id @default(uuid())
  propertyId  String
  name        String?
  street      String
  houseNumber String
  postalCode  String
  city        String
  country     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id])
  units       Unit[]
}

model Unit {
  id               String   @id @default(uuid())
  buildingId       String
  unitNumber       String
  type             UnitType
  floor            Int?
  entrance         String?
  size             Float?
  coOwnershipShare Decimal?
  constructionYear Int?
  rooms            Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  building         Building @relation(fields: [buildingId], references: [id])
}
